# =============================================================================
# Secrets and API keys
# Never commit files that could contain credentials
# =============================================================================
*.env
.env
.env.*
.env.local
.env.*.local

# =============================================================================
# Local configuration overrides
# frugal-vibe.conf is safe to commit (no secrets)
# frugal-vibe.conf.local is for personal overrides and is never committed
# =============================================================================
frugal-vibe.conf.local

# =============================================================================
# Learner install state
# docs/reference/my-setup.md is written by install scripts and is local only
# =============================================================================
docs/reference/my-setup.md
docs/reference/setup-progress.env

# =============================================================================
# macOS
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# Windows
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Linux
# =============================================================================
*~

# =============================================================================
# Editors and IDEs
# =============================================================================
.vscode/settings.json
.idea/
*.swp
*.swo

# =============================================================================
# Logs and temp files
# =============================================================================
*.log
tmp/
temp/
